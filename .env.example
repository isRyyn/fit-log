# Google Drive OAuth (for optional backup)
# Create credentials at console.cloud.google.com
# Application type: Web application
# Authorised JS origin: http://localhost:3000 (dev) + your deployed URL (prod)
# Authorised redirect URI: http://localhost:3000/drive-callback (dev) + deployed URL
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Optional: specific Drive folder ID to upload backups into
VITE_GOOGLE_DRIVE_FOLDER_ID=
